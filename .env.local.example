# Clophy — Environment Variables
# Copy this file to .env.local and fill in the values below.
# Never commit .env.local to source control.

# --- YouTube Data API v3 ---
# Used by the /content page to fetch the latest videos from the
# @MichaelangeloBuilds channel via lib/youtube.ts.
# Create an API key at https://console.cloud.google.com/ (enable
# "YouTube Data API v3" then create credentials > API key).
# Keep this server-side only. Do NOT prefix with NEXT_PUBLIC_.
YOUTUBE_API_KEY=

# --- Contact form (n8n webhook) ---
# Used by app/api/contact/route.ts to forward contact form submissions.
# Set this in Vercel as a server-only env var (Production + Preview).
# Do NOT prefix with NEXT_PUBLIC_ — the webhook URL must stay secret.
N8N_CONTACT_WEBHOOK_URL=
