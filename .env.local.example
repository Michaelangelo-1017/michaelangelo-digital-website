# Michaelangelo Digital — Environment Variables
# Copy this file to .env.local and fill in the values below.
# Never commit .env.local to source control.

# --- YouTube Data API v3 ---
# Used by the /content page to fetch the latest videos from the
# @MichaelangeloBuilds channel via lib/youtube.ts.
# Create an API key at https://console.cloud.google.com/ (enable
# "YouTube Data API v3" then create credentials > API key).
# Keep this server-side only. Do NOT prefix with NEXT_PUBLIC_.
YOUTUBE_API_KEY=

# --- Formspree (reminder only) ---
# Formspree is configured with a hardcoded form endpoint in
# components/contact/ContactForm.tsx. Replace the placeholder
# https://formspree.io/f/YOUR_ID with your real Formspree form
# ID from https://formspree.io/forms before going live.
# This variable is not read at runtime — it exists as a reminder.
FORMSPREE_ENDPOINT=
